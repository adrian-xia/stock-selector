# ===========================================
# Docker 容器内环境变量
# docker compose 通过 env_file 加载此文件
# ===========================================

# --- 应用 ---
APP_ENV=production
LOG_LEVEL=INFO
LOG_FORMAT=json
SKIP_INTEGRITY_CHECK=true

# --- 数据库 (PostgreSQL，局域网 IP 直连) ---
DATABASE_URL=postgresql+asyncpg://postgres:123456@192.168.1.100:5432/stock_selector_prod
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis (宿主机，通过 host.docker.internal 访问) ---
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DB=1
REDIS_PASSWORD=

# --- Tushare ---
TUSHARE_TOKEN=e898fb48fb38f9f9399354e90f9e8e41bf7a52e5827b41ae38ac531c

# --- CORS (局域网访问) ---
CORS_ORIGINS=["http://localhost:5173","http://192.168.1.100:5173"]

# --- AI (Gemini) ---
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL_ID=gemini-2.5-flash

# --- AI (Codex) ---
# 注意：gmn.chuangzuoli.com 使用专有协议
CODEX_API_KEY=
CODEX_BASE_URL=https://gmn.chuangzuoli.com
CODEX_MODEL_ID=gpt-5.3-codex
CODEX_THINKING_DEFAULT=xhigh

# --- 定时任务 ---
AUTO_UPDATE_ENABLED=true
MARKET_OPT_ENABLED=true
